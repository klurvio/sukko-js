{
	"name": "@sukko/vue",
	"version": "0.1.0",
	"description": "Vue 3 composables and provider for Sukko real-time WebSocket SDK",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"sideEffects": false,
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"@sukko/sdk": "workspace:*",
		"vue": ">=3.3"
	},
	"devDependencies": {
		"@sukko/sdk": "workspace:*",
		"@vue/test-utils": "^2",
		"jsdom": "^26",
		"tsup": "^8",
		"typescript": "^5.5",
		"vitest": "^3",
		"vue": "^3.5"
	}
}
